# ─── {{app-name}} UI — Local Dev Environment ─────────────────────────────────
# Copy to .env for local development. The docker-compose mounts this automatically.
# NEVER commit .env with real credentials.
#
# When running via ./dev.sh the backend is at http://localhost:8000 by default.
# The UI container automatically uses VITE_API_URL set here.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (must match PORT_BACKEND in dev.sh / docker-compose.local.yml)
VITE_API_URL=http://localhost:8000/v1

# Cognito — not needed here for local dev; auth is handled by the backend.
# These are injected at deploy time by the reusable static-site workflow.
# VITE_USER_POOL_ID={{cognito-user-pool-id}}
# VITE_USER_POOL_CLIENT_ID={{cognito-client-id}}
# VITE_AWS_REGION={{aws-region}}
